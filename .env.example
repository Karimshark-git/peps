# Not used by the app — PEPS reads keys from lib/env/supabase_env.dart only.
# This file documents the two values you need from Supabase (Settings → API):
#
#   SUPABASE_URL         → Project URL
#   SUPABASE_ANON_KEY    → anon public key
#
# After clone: run ./tool/setup_supabase_env.sh
# or: cp lib/env/supabase_env_example.dart lib/env/supabase_env.dart
# Then paste the URL and anon key into lib/env/supabase_env.dart.

SUPABASE_URL=
SUPABASE_ANON_KEY=
